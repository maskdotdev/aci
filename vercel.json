{
  "routes": [
    {
      "src": "/install.sh",
      "headers": {
        "Content-Type": "text/x-shellscript; charset=utf-8"
      },
      "dest": "/site/install.sh"
    },
    {
      "src": "/",
      "dest": "/site/index.html"
    },
    {
      "src": "/docs",
      "dest": "/site/docs.html"
    },
    {
      "src": "/(.*)",
      "dest": "/site/$1"
    }
  ]
}
